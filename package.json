{
    "name": "alcomd3-website",
    "type": "module",
    "version": "0.1.0",
    "private": true,
    "license": "AGPL-3.0-only",
    "scripts": {
        "generate:theme": "node scripts/generate-theme.mjs",
        "predev": "npm run generate:theme",
        "dev": "astro dev",
        "prestart": "npm run generate:theme",
        "start": "astro dev",
        "precheck": "npm run generate:theme",
        "check": "astro check",
        "prebuild": "npm run generate:theme",
        "build": "astro check && astro build",
        "preview": "astro preview",
        "test": "npm run test:unit && npm run build && npm run test:e2e",
        "test:unit": "node --test tests/unit/*.test.mjs",
        "test:e2e": "playwright test"
    },
    "dependencies": {
        "@astrojs/sitemap": "^3.7.3",
