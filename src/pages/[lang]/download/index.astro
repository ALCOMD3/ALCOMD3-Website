---
import "@/styles/downloads.css";
import AppHeader from "@/components/AppHeader.astro";
import DownloadPanel from "@/components/DownloadPanel.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { languageKeys, locales, siteConfig, type LanguageKey } from "@/data/site";

export function getStaticPaths() {
    return languageKeys.map((lang) => ({
        params: { lang },
        props: { lang },
    }));
}

type Props = {
    lang: LanguageKey;
};

const { lang } = Astro.props;
const locale = locales[lang];
const pagePath = siteConfig.downloadPath;
const pageTitle = `${locale.downloads.sectionTitle} - ${siteConfig.name}`;
---

<BaseLayout
    locale={locale}
    pagePath={pagePath}
    title={pageTitle}
    description={locale.downloads.sectionDescription}
    twitterDescription={locale.downloads.sectionDescription}
    ogImageAlt={locale.downloads.sectionTitle}
>
    <AppHeader locale={locale} pagePath={pagePath} />
    <main>
        <DownloadPanel locale={locale} />
    </main>
</BaseLayout>
