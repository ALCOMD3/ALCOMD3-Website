---
import type { MarkdownInstance } from "astro";
import "@/styles/docs.css";
import AppHeader from "@/components/AppHeader.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCanonicalUrl } from "@/data/seo";
import { languageKeys, locales, siteConfig, type LanguageKey } from "@/data/site";

export function getStaticPaths() {
    return languageKeys.map((lang) => ({
        params: { lang },
        props: { lang },
    }));
}

type Props = {
    lang: LanguageKey;
};

const { lang } = Astro.props;
const locale = locales[lang];
const pagePath = siteConfig.mcpDocsPath;
const docs = import.meta.glob<MarkdownInstance<Record<string, never>>>(
    "../../../content/mcp/*.md",
    { eager: true },
);
const docEntry = Object.entries(docs).find(([path]) => path.endsWith(`/${lang}.md`))?.[1];

if (!docEntry) {
    throw new Error(`Missing MCP documentation for locale: ${lang}`);
}

const Content = docEntry.Content;
const pageTitle = `${locale.mcpDocsPageTitle} - ${siteConfig.name}`;
const canonicalUrl = getCanonicalUrl(lang, pagePath);
const techArticleStructuredData = {
    "@context": "https://schema.org",
    "@type": "TechArticle",
    headline: locale.mcpDocsPageTitle,
    description: locale.mcpDocsPageDescription,
    inLanguage: locale.htmlLang,
    url: canonicalUrl,
    mainEntityOfPage: canonicalUrl,
    about: [
        "ALCOMD3",
        "Model Context Protocol",
        "MCP bridge",
        "VRChat project management",
    ],
    author: {
        "@type": "Organization",
        name: siteConfig.authorName,
        url: siteConfig.authorUrl,
    },
    publisher: {
        "@type": "Organization",
        name: siteConfig.authorName,
        url: siteConfig.authorUrl,
    },
};
---

<BaseLayout
    locale={locale}
    pagePath={pagePath}
    title={pageTitle}
    description={locale.mcpDocsPageDescription}
    twitterDescription={locale.mcpDocsPageDescription}
    ogImageAlt={locale.mcpDocsPageTitle}
    structuredData={techArticleStructuredData}
>
    <AppHeader locale={locale} pagePath={pagePath} />
    <main class="docs-page">
        <div class="site-frame">
            <article class="docs-content">
                <Content />
            </article>
        </div>
    </main>
</BaseLayout>
