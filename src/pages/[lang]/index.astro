---
import Advantages from "@/components/Advantages.astro";
import AppHeader from "@/components/AppHeader.astro";
import Contributors from "@/components/Contributors.astro";
import Hero from "@/components/Hero.astro";
import Positioning from "@/components/Positioning.astro";
import Resources from "@/components/Resources.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { languageKeys, locales, type LanguageKey } from "@/data/site";

export function getStaticPaths() {
    return languageKeys.map((lang) => ({
        params: { lang },
        props: { lang },
    }));
}

type Props = {
    lang: LanguageKey;
};

const { lang } = Astro.props;
const locale = locales[lang];
---

<BaseLayout locale={locale}>
    <AppHeader locale={locale} />
    <main>
        <Hero locale={locale} />
        <Positioning locale={locale} />
        <Advantages locale={locale} />
        <Resources locale={locale} />
        <Contributors locale={locale} />
    </main>
</BaseLayout>
