---
import { getRelativeLocaleUrl } from "astro:i18n";
import {
    defaultUiLocale,
    supportedUiLocales,
    uiLocaleToRouteLocale,
} from "@/data/i18n";
import { themeModeStorageKey, uiLocaleStorageKey } from "@/data/ui-preferences";

const defaultRoute = getRelativeLocaleUrl(uiLocaleToRouteLocale(defaultUiLocale), "");
const routeByLocale = Object.fromEntries(
    supportedUiLocales.map((locale) => [
        locale,
        getRelativeLocaleUrl(uiLocaleToRouteLocale(locale), ""),
    ]),
);
const redirectConfig = {
    defaultUiLocale,
    supportedUiLocales,
    routeByLocale,
    themeModeStorageKey,
    uiLocaleStorageKey,
};
---

<!doctype html>
<html lang="en-US">
    <head>
        <meta charset="utf-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <meta name="robots" content="noindex, nofollow">
        <meta name="color-scheme" content="light dark">
        <title>ALCOMD3</title>
        <script
            is:inline
            type="application/json"
            id="language-redirect-config"
            set:html={JSON.stringify(redirectConfig)}
        />
        <script is:inline>
            (() => {
                const configElement = document.getElementById("language-redirect-config");
                if (!configElement?.textContent) {
                    return;
                }

                const config = JSON.parse(configElement.textContent);
                const supportedLocales = Array.isArray(config.supportedUiLocales)
                    ? config.supportedUiLocales
                    : [];

                function normalizeExactLocale(locale) {
                    if (!locale) {
                        return null;
                    }

                    const normalized = String(locale).trim().replaceAll("_", "-").toLowerCase();
                    return supportedLocales.find(
                        (candidate) => candidate.toLowerCase() === normalized,
                    ) || null;
                }

                function normalizeBrowserLocale(locale) {
                    const exactLocale = normalizeExactLocale(locale);
                    if (exactLocale || !locale) {
                        return exactLocale;
                    }

                    const normalized = String(locale).trim().replaceAll("_", "-").toLowerCase();
                    if (
                        normalized.startsWith("zh-tw")
                        || normalized.startsWith("zh-hk")
                        || normalized.startsWith("zh-mo")
                    ) {
                        return normalizeExactLocale("zh-TW");
                    }
                    if (normalized.startsWith("zh")) {
                        return normalizeExactLocale("zh-CN");
                    }
                    if (normalized.startsWith("ja")) {
                        return normalizeExactLocale("ja-JP");
                    }
                    if (normalized.startsWith("en")) {
                        return normalizeExactLocale("en-US");
                    }

                    return null;
                }

                function getStoredValue(key) {
                    try {
                        return localStorage.getItem(key);
                    } catch {
                        return null;
                    }
                }

                const browserLocales = navigator.languages?.length
                    ? navigator.languages
                    : [navigator.language];
                const storedLocale = normalizeExactLocale(
                    getStoredValue(config.uiLocaleStorageKey),
                );
                const browserLocale = browserLocales.map(normalizeBrowserLocale).find(Boolean);
                const locale = storedLocale
                    || browserLocale
                    || normalizeExactLocale(config.defaultUiLocale)
                    || config.defaultUiLocale;
                const targetRoute = config.routeByLocale?.[locale]
                    || config.routeByLocale?.[config.defaultUiLocale];

                if (targetRoute && window.location.pathname !== targetRoute) {
                    window.location.replace(targetRoute);
                }
            })();
        </script>
        <noscript>
            <meta http-equiv="refresh" content={`0; url=${defaultRoute}`}>
        </noscript>
    </head>
    <body></body>
</html>
