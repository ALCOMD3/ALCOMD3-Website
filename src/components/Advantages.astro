---
import { getRelativeLocaleUrl } from "astro:i18n";
import { siteConfig, type LocaleContent } from "@/data/site";

type Props = {
    locale: LocaleContent;
};

const { locale } = Astro.props;
const mcpIcons = ["hub", "shield_lock", "visibility"];
const appIcons = ["palette", "progress_activity", "system_update_alt", "desktop_windows"];
const mcpAdvantages = locale.advantages.slice(0, 3);
const appAdvantages = locale.advantages.slice(3);
const mcpHref = getRelativeLocaleUrl(locale.lang, siteConfig.mcpDocsPath);
---

<section class="content-section feature-section" aria-labelledby="mcp-section-title">
    <div class="site-frame">
        <div class="section-heading">
            <div>
                <p class="section-kicker">MCP</p>
                <h2 id="mcp-section-title">{locale.mcpSectionTitle}</h2>
            </div>
            <p>{locale.mcpSectionDescription}</p>
        </div>
        <div class="feature-grid feature-grid-three">
            {mcpAdvantages.map((advantage, index) => (
                <article class="feature-card">
                    <span class="feature-icon" aria-hidden="true">
                        <md-icon>{mcpIcons[index]}</md-icon>
                    </span>
                    <h3>{advantage.title}</h3>
                    <p>{advantage.body}</p>
                </article>
            ))}
        </div>
        <div class="section-action">
            <md-filled-tonal-button href={mcpHref}>
                <md-icon slot="icon">menu_book</md-icon>
                {locale.mcpDocsLabel}
            </md-filled-tonal-button>
        </div>
    </div>
</section>

<section class="content-section app-feature-section" aria-labelledby="app-advantages-title">
    <div class="site-frame">
        <div class="section-heading compact-heading">
            <div>
                <p class="section-kicker">Desktop</p>
                <h2 id="app-advantages-title">{locale.appAdvantagesTitle}</h2>
            </div>
        </div>
        <div class="feature-grid feature-grid-four">
            {appAdvantages.map((advantage, index) => (
                <article class="feature-card compact-card">
                    <span class="feature-icon" aria-hidden="true">
                        <md-icon>{appIcons[index]}</md-icon>
                    </span>
                    <h3>{advantage.title}</h3>
                    <p>{advantage.body}</p>
                </article>
            ))}
        </div>
    </div>
</section>

<script>
    import "@material/web/button/filled-tonal-button.js";
    import "@material/web/icon/icon.js";
</script>
